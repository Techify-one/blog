---
import Base from '~/layouts/Base.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import Pagination from '~/components/Pagination.astro';
import { createDb } from '~/db/client';
import { articles, categories } from '~/db/schema';
import { and, desc, eq, sql } from 'drizzle-orm';
import { getSiteConfig } from '~/lib/site';
import { breadcrumbJsonLd } from '~/lib/structured-data';
import { url } from '~/lib/paths';
import { parsePage, parsePageSize } from '~/lib/pagination';

export const prerender = false;

const env = Astro.locals.runtime.env;
const site = getSiteConfig(env);
const db = createDb(env.DB);

const slug = Astro.params.slug;
if (!slug) return new Response('Not Found', { status: 404 });

const catRows = await db
  .select()
  .from(categories)
  .where(eq(categories.slug, slug))
  .limit(1);

if (catRows.length === 0) return new Response('Not Found', { status: 404 });
const category = catRows[0]!;

const limit = parsePageSize(Astro.url.searchParams.get('limit'));
const page = parsePage(Astro.url.searchParams.get('page'));
const offset = (page - 1) * limit;
const where = and(eq(articles.status, 'published'), eq(articles.category, slug));

const [items, totalRow] = await Promise.all([
  db
    .select({
      slug: articles.slug,
      title: articles.title,
      summary: articles.summary,
      category: articles.category,
      published_at: articles.published_at,
      author_name: articles.author_name,
    })
    .from(articles)
    .where(where)
    .orderBy(desc(articles.published_at))
    .limit(limit)
    .offset(offset),
  db.select({ count: sql<number>`count(*)` }).from(articles).where(where),
]);
const total = totalRow[0]?.count ?? 0;

const canonicalUrl = `${site.siteUrl}/categoria/${category.slug}`;

const breadcrumbItems = [
  { name: 'Início', href: site.siteUrl },
  { name: category.name },
];

const jsonLd = breadcrumbJsonLd(
  breadcrumbItems.map((item) => ({ name: item.name, url: item.href })),
);
---

<Base
  title={`${category.name} — ${site.siteName}`}
  description={category.description ?? `Artigos sobre ${category.name}`}
  canonical={canonicalUrl}
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-4xl px-4 py-10">
    <Breadcrumb items={breadcrumbItems.map((b) => ({ name: b.name, href: b.href }))} />

    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-2">{category.name}</h1>
      {category.description && <p class="text-slate-600">{category.description}</p>}
    </header>

    {items.length === 0 ? (
      <p class="text-slate-500">Nenhum artigo nesta categoria ainda.</p>
    ) : (
      <div>
        {items.map((article) => <ArticleCard article={article} />)}
      </div>
    )}

    <Pagination
      page={page}
      total={total}
      limit={limit}
      basePath={url(`/categoria/${category.slug}`)}
    />
  </section>
</Base>
