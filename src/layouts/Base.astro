---
import '../styles/global.css';
import { getSiteConfig } from '~/lib/site';
import { organizationJsonLd, websiteJsonLd } from '~/lib/structured-data';
import { url } from '~/lib/paths';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  articleSection?: string;
  articleTags?: string[];
  articleAuthor?: string;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd,
  articleSection,
  articleTags,
  articleAuthor,
} = Astro.props;

const env = Astro.locals.runtime.env;
const site = getSiteConfig(env);
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.siteUrl).toString();

const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';

// og:image fallback — no artigo, always emit something (hero or logo) so OG never silent.
const effectiveOgImage = ogImage ?? (ogType === 'article' ? site.defaultHeroImageUrl : undefined);

// Site-wide JSON-LD: Organization + WebSite (with SearchAction).
const baseJsonLd = [organizationJsonLd(site.org), websiteJsonLd(site)];
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...baseJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsContent} />
    {articleTags && articleTags.length > 0 && (
      <meta name="keywords" content={articleTags.join(', ')} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content={site.siteName} />
    {effectiveOgImage && <meta property="og:image" content={effectiveOgImage} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleSection && <meta property="article:section" content={articleSection} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {articleTags && articleTags.map((t) => <meta property="article:tag" content={t} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content={effectiveOgImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {effectiveOgImage && <meta name="twitter:image" content={effectiveOgImage} />}

    <link rel="sitemap" href={url('/sitemap.xml')} />
    <link rel="alternate" type="application/rss+xml" title={site.siteName} href={url('/feed.xml')} />

    <!-- JSON-LD structured data -->
    {
      allJsonLd.map((data) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(data)}
        />
      ))
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-4xl px-4 py-5 flex items-center justify-between">
        <a href={url('/')} class="text-lg font-bold text-slate-900 no-underline hover:text-blue-700">
          {site.siteName}
        </a>
        <nav aria-label="Principal" class="text-sm">
          <ul class="flex gap-5">
            <li><a href={url('/')}>Início</a></li>
            <li><a href={site.org.url}>Site principal</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 mt-16">
      <div class="mx-auto max-w-4xl px-4 py-8 text-sm text-slate-600">
        <nav aria-label="Institucional" class="flex flex-wrap gap-4 mb-3">
          <a href={site.org.url}>Site principal</a>
          <a href={`${site.org.url}/sobre`}>Sobre</a>
          <a href={`${site.org.url}/contato`}>Contato</a>
          <a href={url('/sitemap.xml')}>Sitemap</a>
        </nav>
        <p class="text-slate-500">
          &copy; {new Date().getFullYear()} {site.siteName}. {site.siteDescription}
        </p>
      </div>
    </footer>
  </body>
</html>
