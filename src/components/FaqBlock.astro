---
/**
 * FaqBlock — Perguntas frequentes. Renderiza usando <details>/<summary>
 * (semântica nativa, sem JS) e a ordem importa: o RAG gosta de FAQ perto do
 * final do documento. O schema FAQPage é emitido em paralelo via structured-data.
 */

import type { FaqItem } from '~/db/schema';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

{items && items.length > 0 && (
  <section aria-labelledby="faq-h" class="my-10 border-t border-slate-200 pt-8">
    <h2 id="faq-h" class="text-2xl font-semibold tracking-tight mb-4">
      Perguntas frequentes
    </h2>
    <div class="space-y-3">
      {items.map((item, i) => (
        <details
          class="group rounded-md border border-slate-200 bg-white open:bg-slate-50"
          open={i === 0}
        >
          <summary class="cursor-pointer list-none px-4 py-3 font-medium text-slate-900 flex items-center justify-between gap-4">
            <span>{item.q}</span>
            <span
              aria-hidden="true"
              class="text-slate-400 transition-transform group-open:rotate-45"
            >
              +
            </span>
          </summary>
          <div class="px-4 pb-4 text-slate-700 leading-relaxed" set:html={item.a} />
        </details>
      ))}
    </div>
  </section>
)}
