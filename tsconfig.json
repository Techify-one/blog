{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "types": ["@cloudflare/workers-types/2023-07-01", "astro/client"]
  },
  "include": ["src", "./*.d.ts", "./worker-configuration.d.ts"],
  "exclude": ["dist", ".wrangler", "node_modules"]
}
