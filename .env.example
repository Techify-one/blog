# Cloudflare deploy credentials — used by `wrangler` CLI.
# Generate at https://dash.cloudflare.com/profile/api-tokens
# (token needs Workers Scripts:Edit + D1:Edit + Account:Read).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Used by astro.config.mjs at build time as the `site` URL (canonical, sitemap, OG).
# Should match SITE_URL in wrangler.toml [vars].
SITE_HOST=https://example.com/blog

# Public URL of the deployed blog API + Bearer token used by automation scripts
# (the same value you set with `wrangler secret put API_KEY`).
BLOG_URL=https://example.com/blog
BLOG_KEY=replace-with-your-api-key
